# Copy this file to .env and fill in real values. .env is gitignored —
# never commit actual credentials.

# Required. API key for the Anthropic provider (src/gaps/llm/anthropic_provider.py).
ANTHROPIC_API_KEY=

# Optional. Overrides the default Claude model used for drafting outreach.
# Defaults to a small/cheap model (see llm/anthropic_provider.py DEFAULT_MODEL)
# if unset.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
